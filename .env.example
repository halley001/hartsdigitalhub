# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Get your API key from: https://platform.openai.com/api-keys

# Email Configuration for Visitor Info Collection
# For Gmail: Use an App Password (not your regular password)
# 1. Go to Google Account > Security > 2-Step Verification
# 2. Scroll down to "App passwords"
# 3. Generate a new app password for "Mail"
# 4. Use that 16-character password below

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Where to send visitor information (can be same as EMAIL_USER)
RECIPIENT_EMAIL=your-email@gmail.com

# Alternative Email Services:
# For Outlook/Hotmail: service: 'outlook'
# For Yahoo: service: 'yahoo'
# For custom SMTP:
#   host: smtp.your-domain.com
#   port: 587
#   secure: false
